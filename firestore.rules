rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Collection ---
    match /users/{userId} {
      // Allow single document fetch (get) so survey pages can show the user's name
      // Prevent listing all users (list) for privacy.
      allow get: if true;
      allow list: if request.auth != null && request.auth.token.email == 'gkilon@gmail.com';
      
      // Only the authenticated user can create or update their own record
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // --- Settings Collection ---
    match /settings/config {
      // Settings must be readable to check invite codes
      allow read: if true;
      // Only the specified admin email can change settings
      allow write: if request.auth != null && request.auth.token.email == 'gkilon@gmail.com';
    }

    // --- Responses Collection ---
    match /responses/{responseId} {
      // Anyone can create a response (unauthenticated feedback)
      allow create: if true;
      
      // Reading responses requires being the survey owner or admin
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.surveyId || 
        request.auth.token.email == 'gkilon@gmail.com'
      );
      
      allow update, delete: if false;
    }

    // --- Analysis Collection ---
    match /analysis/{userId} {
      // Only the user themselves or the admin can read/write analysis
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'gkilon@gmail.com'
      );
    }
  }
}

