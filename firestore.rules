rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Collection ---
    match /users/{userId} {
      // Anyone authenticated can read (allows finding users by email for the registration check)
      // or we can restrict it to their own record if `findUserByEmail` doesn't strictly need auth.
      // But for security, let's allow read if authenticated. If `findUserByEmail` is called during login/register,
      // Firebase auth is already active.
      allow read: if request.auth != null; 
      
      // A user can create or update their own document
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // --- Settings Collection ---
    match /settings/config {
      // Anyone can read the settings (to see registration codes and questions)
      allow read: if true;
      // Only the specified admin email can change settings
      allow write: if request.auth != null && request.auth.token.email == 'gkilon@gmail.com';
    }

    // --- Responses Collection ---
    match /responses/{responseId} {
      // Anyone can create a response (unauthenticated feedback)
      allow create: if true;
      
      // Only the owner of the survey OR the admin can read the responses
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.surveyId || 
        request.auth.token.email == 'gkilon@gmail.com'
      );
      
      allow update, delete: if false;
    }
  }
}
